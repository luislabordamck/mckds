{
  "name": "@mckmds/ui",
  "version": "0.1.15",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "guidelines", "scripts/postinstall.js"],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "tsup src/index.ts --format cjs,esm --no-dts --out-dir dist && cp app/tokens.css dist/styles.css",
    "start": "next start",
    "lint": "eslint",
    "tokens": "node scripts/build-tokens.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "style-dictionary": "^5.4.0",
    "tailwindcss": "^4",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}